# Supabase — public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: public domain for cafe routing
NEXT_PUBLIC_BARNDAKSA_PUBLIC_DOMAIN=

# Optional: Vercel domain purchase (server routes only)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_DOMAIN_PURCHASE_LIVE=

# PayPal / Barndaksa electronic card payments
PAYPAL_ENV=live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
PAYPAL_USD_SAR_RATE=3.75

# Paymob / Barndaksa subscription payments — server only unless prefixed NEXT_PUBLIC
PAYMOB_ENV=live
PAYMOB_REGION=ksa
PAYMOB_API_BASE_URL=https://ksa.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://ksa.paymob.com/unifiedcheckout
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_PAYMENT_METHOD_IDS=
PAYMOB_CARD_INTEGRATION_ID=
PAYMOB_MADA_INTEGRATION_ID=
PAYMOB_APPLE_PAY_INTEGRATION_ID=
PAYMOB_STCPAY_INTEGRATION_ID=
PAYMOB_CURRENCY=SAR
PAYMOB_REQUIRE_HMAC=false
NEXT_PUBLIC_APP_URL=https://barndaksa.com
